---
export const prerender = false;
import '../styles/globals.css';
import Header from '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="運転免許証情報 - キャンピングカーレンタル" />
    <title>運転免許証情報 | キャンピングカーレンタル</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Header />

    <main class="container mx-auto max-w-3xl px-4 py-12">
      <div id="loading" class="py-12 text-center text-muted-foreground">
        読み込み中...
      </div>

      <div id="content" class="hidden">
        <div class="mb-6 flex items-center justify-between">
          <h1 class="text-2xl font-bold md:text-3xl">運転免許証情報</h1>
          <a href="/mypage" class="text-sm font-medium text-primary hover:underline">
            ← マイページに戻る
          </a>
        </div>

        <div class="overflow-hidden rounded-xl border border-border bg-card shadow-sm">
          <div class="border-b border-border bg-muted/50 px-6 py-4">
            <h2 class="font-semibold text-foreground">登録内容</h2>
          </div>
          <dl class="divide-y divide-border">
            <div class="grid grid-cols-1 gap-1 p-6 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-muted-foreground">免許証番号</dt>
              <dd class="text-foreground sm:col-span-2" id="val-number">—</dd>
            </div>

            <div class="grid grid-cols-1 gap-1 p-6 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-muted-foreground">免許証の色</dt>
              <dd class="text-foreground sm:col-span-2" id="val-color">—</dd>
            </div>

            <div class="grid grid-cols-1 gap-1 p-6 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-muted-foreground">生年月日</dt>
              <dd class="text-foreground sm:col-span-2" id="val-birthday">—</dd>
            </div>

            <div class="grid grid-cols-1 gap-1 p-6 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-muted-foreground">有効期限</dt>
              <dd class="text-foreground sm:col-span-2" id="val-expire">—</dd>
            </div>

            <div class="grid grid-cols-1 gap-1 p-6 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-muted-foreground">免許の種類</dt>
              <dd class="text-foreground sm:col-span-2" id="val-type">—</dd>
            </div>

            <div class="grid grid-cols-1 gap-1 p-6 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-muted-foreground">メモ</dt>
              <dd class="text-foreground sm:col-span-2 whitespace-pre-wrap" id="val-memo">—</dd>
            </div>
          </dl>

          <div class="border-t border-border bg-muted/50 px-6 py-4">
            <h2 class="font-semibold text-foreground">登録画像</h2>
          </div>
          <div class="grid grid-cols-1 gap-6 p-6 sm:grid-cols-2">
            <div class="space-y-2">
              <div class="text-sm font-medium text-muted-foreground">免許証（表面）</div>
              <div id="wrap-img-front" class="hidden">
                <a id="link-img-front" href="#" target="_blank" rel="noopener noreferrer" class="block transition-opacity hover:opacity-90">
                  <img id="img-front" src="" alt="免許証（表面）" class="h-48 w-full rounded-lg border border-border object-contain bg-muted/20" />
                </a>
              </div>
              <p id="no-img-front" class="text-sm text-foreground">—</p>
            </div>

            <div class="space-y-2">
              <div class="text-sm font-medium text-muted-foreground">免許証（裏面）</div>
              <div id="wrap-img-back" class="hidden">
                <a id="link-img-back" href="#" target="_blank" rel="noopener noreferrer" class="block transition-opacity hover:opacity-90">
                  <img id="img-back" src="" alt="免許証（裏面）" class="h-48 w-full rounded-lg border border-border object-contain bg-muted/20" />
                </a>
              </div>
              <p id="no-img-back" class="text-sm text-foreground">—</p>
            </div>

            <div class="space-y-2">
              <div class="text-sm font-medium text-muted-foreground">住所確認書類</div>
              <div id="wrap-img-address" class="hidden">
                <a id="link-img-address" href="#" target="_blank" rel="noopener noreferrer" class="block transition-opacity hover:opacity-90">
                  <img id="img-address" src="" alt="住所確認書類" class="h-48 w-full rounded-lg border border-border object-contain bg-muted/20" />
                </a>
              </div>
              <p id="no-img-address" class="text-sm text-foreground">—</p>
            </div>

            <div class="space-y-2">
              <div class="text-sm font-medium text-muted-foreground">本人確認書類</div>
              <div id="wrap-img-id" class="hidden">
                <a id="link-img-id" href="#" target="_blank" rel="noopener noreferrer" class="block transition-opacity hover:opacity-90">
                  <img id="img-id" src="" alt="本人確認書類" class="h-48 w-full rounded-lg border border-border object-contain bg-muted/20" />
                </a>
              </div>
              <p id="no-img-id" class="text-sm text-foreground">—</p>
            </div>
          </div>
        </div>

        <div class="mt-8 text-center">
          <a href="/mypage" class="rounded-md bg-secondary px-6 py-2.5 text-sm font-medium text-secondary-foreground hover:bg-secondary/80">
            マイページに戻る
          </a>
        </div>
      </div>
    </main>

    <script>
      import { initAuth } from '../lib/auth';
      import { getDb } from '../lib/firebase';
      import { collection, query, where, getDocs } from 'firebase/firestore';

      const loadingEl = document.getElementById('loading');
      const contentEl = document.getElementById('content');

      const elNumber = document.getElementById('val-number');
      const elColor = document.getElementById('val-color');
      const elBirthday = document.getElementById('val-birthday');
      const elExpire = document.getElementById('val-expire');
      const elType = document.getElementById('val-type');
      const elMemo = document.getElementById('val-memo');

      function formatDate(ts: unknown): string {
        if (!ts) return '—';
        const d = ts && typeof (ts as { toDate?: () => Date }).toDate === 'function'
          ? (ts as { toDate: () => Date }).toDate()
          : new Date(ts as string | number | Date);
        if (isNaN(d.getTime())) return '—';
        return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
      }

      function setupImage(
        url: string | undefined,
        wrapId: string,
        imgId: string,
        linkId: string,
        noImgId: string
      ): void {
        const wrapEl = document.getElementById(wrapId);
        const imgEl = document.getElementById(imgId) as HTMLImageElement | null;
        const linkEl = document.getElementById(linkId) as HTMLAnchorElement | null;
        const noImgEl = document.getElementById(noImgId);
        const hasUrl = !!url && url.trim() !== '';
        if (hasUrl) {
          if (imgEl) imgEl.src = url!;
          if (linkEl) linkEl.href = url!;
          if (wrapEl) wrapEl.classList.remove('hidden');
          if (noImgEl) noImgEl.classList.add('hidden');
        } else {
          if (wrapEl) wrapEl.classList.add('hidden');
          if (noImgEl) noImgEl.classList.remove('hidden');
        }
      }

      initAuth(async (user) => {
        if (!user) {
          window.location.href = '/login';
          return;
        }

        const db = getDb();
        if (!db) return;

        try {
          const q = query(collection(db, 'licenses'), where('user_id', '==', user.uid));
          const querySnapshot = await getDocs(q);

          if (querySnapshot.empty) {
            alert('免許証情報が見つかりません。まずは登録を行ってください。');
            window.location.href = '/mypage';
            return;
          }

          const docData = querySnapshot.docs[0].data();

          if (elNumber) elNumber.textContent = (docData.license_number as string) || '—';
          if (elColor) elColor.textContent = (docData.license_color as string) || '—';
          if (elBirthday) elBirthday.textContent = formatDate(docData.birthday);
          if (elExpire) elExpire.textContent = formatDate(docData.license_expiration_date);
          if (elType) elType.textContent = (docData.license_type as string) || '—';
          if (elMemo) elMemo.textContent = (docData.memo as string) || 'なし';

          setupImage(docData.license_front_image as string | undefined, 'wrap-img-front', 'img-front', 'link-img-front', 'no-img-front');
          setupImage(docData.license_back_image as string | undefined, 'wrap-img-back', 'img-back', 'link-img-back', 'no-img-back');
          setupImage(docData.address_verification_image as string | undefined, 'wrap-img-address', 'img-address', 'link-img-address', 'no-img-address');
          setupImage(docData.identification_image as string | undefined, 'wrap-img-id', 'img-id', 'link-img-id', 'no-img-id');

          if (loadingEl) loadingEl.classList.add('hidden');
          if (contentEl) contentEl.classList.remove('hidden');
        } catch (err) {
          console.error(err);
          alert('データの取得に失敗しました。');
          window.location.href = '/mypage';
        }
      });
    </script>
  </body>
</html>
