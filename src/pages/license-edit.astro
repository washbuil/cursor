---
export const prerender = false;
import '../styles/globals.css';
import Header from '../components/Header.astro';

const currentYear = new Date().getFullYear();
const birthYears = Array.from({ length: 80 }, (_, i) => currentYear - 18 - i);
const expireYears = Array.from({ length: 15 }, (_, i) => currentYear + i);
const months = Array.from({ length: 12 }, (_, i) => i + 1);
const days = Array.from({ length: 31 }, (_, i) => i + 1);

const LICENSE_COLORS = ['グリーン', 'ブルー', 'ゴールド'];
const LICENSE_TYPES = ['普通', '普通AT限定', '準中型', '準中型AT限定', '中型', '中型AT限定', '大型', '大型AT限定'];
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="運転免許証編集 - キャンピングカーレンタル" />
    <title>運転免許証編集 | キャンピングカーレンタル</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Header />

    <main class="container mx-auto max-w-2xl px-4 py-12">
      <div id="loading" class="py-12 text-center text-muted-foreground">読み込み中...</div>

      <div id="content" class="hidden">
        <h1 class="mb-6 text-2xl font-bold">運転免許証情報の編集</h1>
        <p class="mb-8 text-sm text-muted-foreground">
          変更箇所を入力し、画像を再登録する場合はファイルを選択してください。<br />
          画像を変更しない場合は、ファイルを選択せずにそのままで構いません。
        </p>

        <form id="edit-form" class="space-y-6 rounded-xl border border-border bg-card p-6 shadow-sm">
          <div class="space-y-2">
            <label class="text-sm font-medium">生年月日</label>
            <div class="flex gap-2">
              <select name="birth_year" required class="w-full rounded-md border border-input bg-background px-3 py-2">
                <option value="">年</option>
                {birthYears.map((y) => <option value={y}>{y}</option>)}
              </select>
              <select name="birth_month" required class="w-full rounded-md border border-input bg-background px-3 py-2">
                <option value="">月</option>
                {months.map((m) => <option value={m}>{m}</option>)}
              </select>
              <select name="birth_day" required class="w-full rounded-md border border-input bg-background px-3 py-2">
                <option value="">日</option>
                {days.map((d) => <option value={d}>{d}</option>)}
              </select>
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">免許証番号</label>
            <input type="text" name="license_number" required maxlength="12" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">免許証の色</label>
            <select name="license_color" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2">
              <option value="">選択してください</option>
              {LICENSE_COLORS.map((c) => <option value={c}>{c}</option>)}
            </select>
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">有効期限</label>
            <div class="flex gap-2">
              <select name="expire_year" required class="w-full rounded-md border border-input bg-background px-3 py-2">
                <option value="">年</option>
                {expireYears.map((y) => <option value={y}>{y}</option>)}
              </select>
              <select name="expire_month" required class="w-full rounded-md border border-input bg-background px-3 py-2">
                <option value="">月</option>
                {months.map((m) => <option value={m}>{m}</option>)}
              </select>
              <select name="expire_day" required class="w-full rounded-md border border-input bg-background px-3 py-2">
                <option value="">日</option>
                {days.map((d) => <option value={d}>{d}</option>)}
              </select>
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">免許の種類</label>
            <select name="license_type" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2">
              <option value="">選択してください</option>
              {LICENSE_TYPES.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">メモ</label>
            <textarea name="memo" rows="3" class="flex w-full rounded-md border border-input bg-background px-3 py-2"></textarea>
          </div>

          <div class="space-y-6 rounded-md border border-muted p-6">
            <h3 class="font-semibold text-lg">画像の変更（任意）</h3>
            
            <div class="space-y-2">
              <div class="flex items-center justify-between">
                <label class="text-sm font-medium">免許証（表面）</label>
                <button type="button" id="reset-front" class="text-xs text-muted-foreground hover:underline hidden">元に戻す</button>
              </div>
              <div class="relative mb-2 h-48 w-full overflow-hidden rounded-md border border-input bg-muted/20">
                <img id="prev-front" class="h-full w-full object-contain hidden" />
                <div id="txt-front" class="flex h-full w-full items-center justify-center text-sm text-muted-foreground">未登録</div>
              </div>
              <input type="file" name="license_image" accept="image/*" class="w-full text-sm" />
            </div>

            <div class="space-y-2">
              <div class="flex items-center justify-between">
                <label class="text-sm font-medium">免許証（裏面）</label>
                <button type="button" id="reset-back" class="text-xs text-muted-foreground hover:underline hidden">元に戻す</button>
              </div>
              <div class="relative mb-2 h-48 w-full overflow-hidden rounded-md border border-input bg-muted/20">
                <img id="prev-back" class="h-full w-full object-contain hidden" />
                <div id="txt-back" class="flex h-full w-full items-center justify-center text-sm text-muted-foreground">未登録</div>
              </div>
              <input type="file" name="license_back_image" accept="image/*" class="w-full text-sm" />
            </div>

            <div class="space-y-2">
              <div class="flex items-center justify-between">
                <label class="text-sm font-medium">住所確認書類</label>
                <button type="button" id="reset-address" class="text-xs text-muted-foreground hover:underline hidden">元に戻す</button>
              </div>
              <div class="relative mb-2 h-48 w-full overflow-hidden rounded-md border border-input bg-muted/20">
                <img id="prev-address" class="h-full w-full object-contain hidden" />
                <div id="txt-address" class="flex h-full w-full items-center justify-center text-sm text-muted-foreground">未登録</div>
              </div>
              <input type="file" name="address_verification_image" accept="image/*" class="w-full text-sm" />
            </div>

            <div class="space-y-2">
              <div class="flex items-center justify-between">
                <label class="text-sm font-medium">本人確認書類</label>
                <button type="button" id="reset-id" class="text-xs text-muted-foreground hover:underline hidden">元に戻す</button>
              </div>
              <div class="relative mb-2 h-48 w-full overflow-hidden rounded-md border border-input bg-muted/20">
                <img id="prev-id" class="h-full w-full object-contain hidden" />
                <div id="txt-id" class="flex h-full w-full items-center justify-center text-sm text-muted-foreground">未登録</div>
              </div>
              <input type="file" name="identification_image" accept="image/*" class="w-full text-sm" />
            </div>
          </div>

          <div class="flex gap-4">
            <a href="/license-info" class="flex-1 rounded-md border border-input bg-background py-3 text-center text-sm font-medium hover:bg-accent hover:text-accent-foreground">
              キャンセル
            </a>
            <button type="submit" id="submit-btn" class="flex-1 rounded-md bg-primary py-3 text-sm font-medium text-primary-foreground hover:opacity-90 disabled:opacity-50">
              更新する
            </button>
          </div>
        </form>
      </div>
    </main>

    <script>
      import { initAuth, getCurrentUser } from '../lib/auth';
      import { getDb, getFirebaseStorage } from '../lib/firebase';
      import { collection, query, where, getDocs, updateDoc, doc } from 'firebase/firestore';
      import type { Timestamp } from 'firebase/firestore';
      import { ref, uploadBytes, getDownloadURL, type FirebaseStorage } from 'firebase/storage';

      const loadingEl = document.getElementById('loading');
      const contentEl = document.getElementById('content');
      const form = document.getElementById('edit-form') as HTMLFormElement | null;
      const submitBtn = document.getElementById('submit-btn');

      let licenseDocId = '';
      let currentData: Record<string, unknown> = {};

      async function uploadImage(storageInstance: FirebaseStorage, file: File, userId: string, fileName: string): Promise<string> {
        const path = `licenses/${userId}/${fileName}`;
        const storageRef = ref(storageInstance, path);
        await uploadBytes(storageRef, file);
        return await getDownloadURL(storageRef);
      }

      // 画像プレビュー制御関数（リセット機能付き）
      function setupImagePreview(inputName: string, imgId: string, txtId: string, resetBtnId: string, initialUrl: string | undefined) {
        const input = form?.querySelector(`input[name="${inputName}"]`) as HTMLInputElement;
        const img = document.getElementById(imgId) as HTMLImageElement;
        const txt = document.getElementById(txtId);
        const resetBtn = document.getElementById(resetBtnId);

        // プレビュー表示を更新する内部関数
        const updateView = (url: string | undefined | null) => {
          if (url) {
            img.src = url;
            img.classList.remove('hidden');
            txt?.classList.add('hidden');
          } else {
            img.src = '';
            img.classList.add('hidden');
            txt?.classList.remove('hidden');
          }
        };

        // 初期表示
        updateView(initialUrl);

        // 変更時イベント
        input?.addEventListener('change', (e) => {
          const file = (e.target as HTMLInputElement).files?.[0];
          if (file) {
            const url = URL.createObjectURL(file);
            updateView(url);
            // ファイルが選択されたらリセットボタンを表示
            resetBtn?.classList.remove('hidden');
          }
        });

        // リセットボタンクリックイベント
        resetBtn?.addEventListener('click', () => {
          // ファイル入力をクリア
          input.value = '';
          // プレビューを初期URLに戻す
          updateView(initialUrl);
          // リセットボタンを隠す
          resetBtn.classList.add('hidden');
          // createObjectURLで作成したURLを開放する（メモリリーク防止）
          if (img.src.startsWith('blob:')) {
            URL.revokeObjectURL(img.src);
          }
        });
      }

      function setDateSelects(dateObj: unknown, prefix: string): void {
        if (!dateObj) return;
        const d = dateObj && typeof (dateObj as { toDate?: () => Date }).toDate === 'function'
            ? (dateObj as { toDate: () => Date }).toDate()
            : new Date(dateObj as string | number);
        if (isNaN(d.getTime())) return;

        const yEl = form?.querySelector(`[name="${prefix}_year"]`) as HTMLSelectElement | null;
        const mEl = form?.querySelector(`[name="${prefix}_month"]`) as HTMLSelectElement | null;
        const dEl = form?.querySelector(`[name="${prefix}_day"]`) as HTMLSelectElement | null;
        if (yEl) yEl.value = String(d.getFullYear());
        if (mEl) mEl.value = String(d.getMonth() + 1);
        if (dEl) dEl.value = String(d.getDate());
      }

      initAuth(async (user) => {
        if (!user) {
          window.location.href = '/login';
          return;
        }

        const db = getDb();
        if (!db) return;

        try {
          const q = query(collection(db, 'licenses'), where('user_id', '==', user.uid));
          const querySnapshot = await getDocs(q);

          if (querySnapshot.empty) {
            alert('免許証情報が見つかりません。');
            window.location.href = '/mypage';
            return;
          }

          const docSnapshot = querySnapshot.docs[0];
          licenseDocId = docSnapshot.id;
          currentData = docSnapshot.data();

          if (!form) return;

          const setVal = (name: string, val: unknown) => {
            const el = form.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
            if (el) el.value = val != null ? String(val) : '';
          };

          setVal('license_number', currentData.license_number);
          setVal('license_color', currentData.license_color);
          setVal('license_type', currentData.license_type);
          setVal('memo', currentData.memo);

          setDateSelects(currentData.birthday, 'birth');
          setDateSelects(currentData.license_expiration_date, 'expire');

          // 画像プレビュー設定（リセットボタンIDを追加）
          setupImagePreview('license_image', 'prev-front', 'txt-front', 'reset-front', currentData.license_front_image as string);
          setupImagePreview('license_back_image', 'prev-back', 'txt-back', 'reset-back', currentData.license_back_image as string);
          setupImagePreview('address_verification_image', 'prev-address', 'txt-address', 'reset-address', currentData.address_verification_image as string);
          setupImagePreview('identification_image', 'prev-id', 'txt-id', 'reset-id', currentData.identification_image as string);

          loadingEl?.classList.add('hidden');
          contentEl?.classList.remove('hidden');
        } catch (err) {
          console.error(err);
          alert('データの読み込みに失敗しました。');
        }
      });

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const user = getCurrentUser();
        if (!licenseDocId || !user || !submitBtn || !form) return;

        submitBtn.disabled = true;
        submitBtn.textContent = '更新中...';

        try {
          const fd = new FormData(form);
          const db = getDb();
          const storageInstance = getFirebaseStorage();
          if (!db) throw new Error('DB Error');

          const birthY = Number(fd.get('birth_year'));
          const birthM = Number(fd.get('birth_month'));
          const birthD = Number(fd.get('birth_day'));
          const expireY = Number(fd.get('expire_year'));
          const expireM = Number(fd.get('expire_month'));
          const expireD = Number(fd.get('expire_day'));

          let frontUrl = (currentData.license_front_image as string) ?? '';
          let backUrl = (currentData.license_back_image as string) ?? '';
          let addressUrl = (currentData.address_verification_image as string) ?? '';
          let idUrl = (currentData.identification_image as string) ?? '';

          if (storageInstance) {
            const fFront = (form.querySelector('input[name="license_image"]') as HTMLInputElement | null)?.files?.[0];
            const fBack = (form.querySelector('input[name="license_back_image"]') as HTMLInputElement | null)?.files?.[0];
            const fAddress = (form.querySelector('input[name="address_verification_image"]') as HTMLInputElement | null)?.files?.[0];
            const fId = (form.querySelector('input[name="identification_image"]') as HTMLInputElement | null)?.files?.[0];
            
            // ファイルが選択されている場合のみアップロードしてURL更新
            if (fFront) frontUrl = await uploadImage(storageInstance, fFront, user.uid, 'license_face.jpg');
            if (fBack) backUrl = await uploadImage(storageInstance, fBack, user.uid, 'license_back_image.jpg');
            if (fAddress) addressUrl = await uploadImage(storageInstance, fAddress, user.uid, 'license_address_image.jpg');
            if (fId) idUrl = await uploadImage(storageInstance, fId, user.uid, 'license_identify_image.jpg');
          }

          const updateData = {
            license_number: fd.get('license_number') ?? '',
            birthday: new Date(birthY, birthM - 1, birthD),
            license_color: fd.get('license_color') ?? '',
            license_expiration_date: new Date(expireY, expireM - 1, expireD),
            license_type: fd.get('license_type') ?? '',
            memo: (fd.get('memo') ?? '').toString().trim(),
            license_front_image: frontUrl,
            license_back_image: backUrl,
            address_verification_image: addressUrl,
            identification_image: idUrl,
            updated_at: new Date(),
          };

          await updateDoc(doc(db, 'licenses', licenseDocId), updateData);

          alert('免許証情報を更新しました。');
          window.location.href = '/license-info';
        } catch (err) {
          console.error(err);
          alert('更新に失敗しました。');
          submitBtn.disabled = false;
          submitBtn.textContent = '更新する';
        }
      });
    </script>
  </body>
</html>