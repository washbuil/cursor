---
export const prerender = false;
import '../styles/globals.css';
import Header from '../components/Header.astro';

const PREFECTURES = [
  '北海道', '青森県', '岩手県', '宮城県', '秋田県', '山形県', '福島県',
  '茨城県', '栃木県', '群馬県', '埼玉県', '千葉県', '東京都', '神奈川県',
  '新潟県', '富山県', '石川県', '福井県', '山梨県', '長野県', '岐阜県',
  '静岡県', '愛知県', '三重県', '滋賀県', '京都府', '大阪府', '兵庫県',
  '奈良県', '和歌山県', '鳥取県', '島根県', '岡山県', '広島県', '山口県',
  '徳島県', '香川県', '愛媛県', '高知県', '福岡県', '佐賀県', '長崎県',
  '熊本県', '大分県', '宮崎県', '鹿児島県', '沖縄県',
];
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="会員情報編集 - キャンピングカーレンタル" />
    <title>会員情報編集 | キャンピングカーレンタル</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Header />

    <main class="container mx-auto max-w-2xl px-4 py-12">
      <div id="loading" class="py-12 text-center text-muted-foreground">
        読み込み中...
      </div>

      <div id="form-wrap" class="hidden">
        <div class="mb-8 text-center">
          <h1 class="text-2xl font-bold md:text-3xl">会員情報の編集</h1>
          <p class="mt-2 text-muted-foreground">変更箇所を入力して送信ボタンを押してください。</p>
        </div>

        <form id="edit-form" class="space-y-6 rounded-xl border border-border bg-card p-6 shadow-sm md:p-8">
          <div class="space-y-2">
            <label class="text-sm font-medium">お名前 (姓・名)</label>
            <div class="grid grid-cols-2 gap-4">
              <input type="text" name="last_name" placeholder="姓" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
              <input type="text" name="first_name" placeholder="名" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">フリガナ (セイ・メイ)</label>
            <div class="grid grid-cols-2 gap-4">
              <input type="text" name="last_name_kana" placeholder="セイ" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
              <input type="text" name="first_name_kana" placeholder="メイ" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">携帯電話番号</label>
            <input type="tel" name="mobile_phone" placeholder="09012345678" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
          </div>
          <div class="space-y-2">
            <label class="text-sm font-medium">自宅電話番号 (任意)</label>
            <input type="tel" name="phone_number" placeholder="0312345678" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="space-y-2">
              <label class="text-sm font-medium">郵便番号</label>
              <input type="text" name="postal_code" placeholder="123-4567" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-medium">都道府県</label>
              <select name="prf" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2">
                <option value="">選択してください</option>
                {PREFECTURES.map((pref) => (
                  <option value={pref}>{pref}</option>
                ))}
              </select>
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-sm font-medium">住所 (市区町村・番地)</label>
            <input type="text" name="address" placeholder="〇〇市〇〇区〇〇町〇番地" required class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
          </div>
          <div class="space-y-2">
            <label class="text-sm font-medium">建物名・部屋番号</label>
            <input type="text" name="room_number" placeholder="〇〇マンション 101号室" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2" />
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">お支払い方法</label>
            <select name="payment_method" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2">
              <option value="銀行振込">銀行振込</option>
              <option value="クレジットカード">クレジットカード</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-sm font-medium">ペット乗車</label>
            <select name="pet_ride" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2">
              <option value="ペット乗車なし">ペット乗車なし</option>
              <option value="ペット乗車あり">ペット乗車あり</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-sm font-medium">メモ (任意)</label>
            <textarea name="memo" rows="3" placeholder="備考があれば入力" class="flex w-full rounded-md border border-input bg-background px-3 py-2"></textarea>
          </div>

          <div class="flex gap-4">
            <a href="/member-info" class="flex-1 rounded-md border border-input bg-background py-3 text-center text-sm font-medium hover:bg-accent hover:text-accent-foreground">
              キャンセル
            </a>
            <button type="submit" id="submit-btn" class="flex-1 rounded-md bg-primary py-3 text-sm font-medium text-primary-foreground hover:opacity-90 disabled:opacity-50">
              更新する
            </button>
          </div>
        </form>
      </div>
    </main>

    <script define:vars={{ apiToken: import.meta.env.PUBLIC_API_TOKEN }}>
      window.pageData = { apiToken };
    </script>

    <script>
      import { initAuth, getCurrentUser } from '../lib/auth';
      import { getDb } from '../lib/firebase';
      import { collection, query, where, getDocs, updateDoc, doc } from 'firebase/firestore';

      const loadingEl = document.getElementById('loading');
      const formWrapEl = document.getElementById('form-wrap');
      const form = document.getElementById('edit-form') as HTMLFormElement | null;
      const submitBtn = document.getElementById('submit-btn');

      const pageData = (window as { pageData?: { apiToken?: string } }).pageData;
      const apiToken = pageData?.apiToken ?? '';
      let memberDocId = '';
      let currentMemberCode = '';

      const postalCodeInput = document.querySelector('input[name="postal_code"]');
      const prfSelect = document.querySelector('select[name="prf"]');
      const addressInput = document.querySelector('input[name="address"]');

      if (postalCodeInput && prfSelect && addressInput) {
        postalCodeInput.addEventListener('input', async (e) => {
          const val = (e.target as HTMLInputElement).value.replace(/-/g, '');
          if (val.length === 7) {
            try {
              const res = await fetch(`https://zipcloud.ibsnet.co.jp/api/search?zipcode=${val}`);
              const data = await res.json();
              if (data.status === 200 && data.results) {
                const result = data.results[0];
                (prfSelect as HTMLSelectElement).value = result.address1;
                (addressInput as HTMLInputElement).value = result.address2 + (result.address3 || '');
              }
            } catch (err) {
              console.error(err);
            }
          }
        });
      }

      initAuth(async (user) => {
        if (!user) {
          window.location.href = '/login';
          return;
        }

        const db = getDb();
        if (!db) return;

        try {
          const q = query(collection(db, 'members'), where('user_id', '==', user.uid));
          const querySnapshot = await getDocs(q);

          if (querySnapshot.empty) {
            alert('会員情報が見つかりません。');
            window.location.href = '/mypage';
            return;
          }

          const docSnapshot = querySnapshot.docs[0];
          memberDocId = docSnapshot.id;
          const data = docSnapshot.data();
          currentMemberCode = (data.member_code as string) ?? '';

          if (!form) return;

          const setVal = (name: string, val: unknown) => {
            const el = form.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
            if (el) el.value = val != null ? String(val) : '';
          };

          setVal('last_name', data.last_name);
          setVal('first_name', data.first_name);
          setVal('last_name_kana', data.last_name_kana);
          setVal('first_name_kana', data.first_name_kana);
          setVal('mobile_phone', data.mobile_phone);
          setVal('phone_number', data.phone_number ?? data.home_phone);
          setVal('postal_code', data.postal_code ?? data.post_code);
          setVal('prf', data.prf ?? data.prefectures);
          setVal('address', data.address);
          setVal('room_number', data.room_number);
          setVal('payment_method', data.payment_method);
          setVal('pet_ride', data.pet_ride ?? data.pet);
          setVal('memo', data.memo);

          loadingEl?.classList.add('hidden');
          formWrapEl?.classList.remove('hidden');
        } catch (err) {
          console.error(err);
          alert('データの読み込みに失敗しました。');
        }
      });

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!memberDocId || !submitBtn) return;

        submitBtn.disabled = true;
        submitBtn.textContent = '更新中...';

        try {
          const fd = new FormData(form!);
          const db = getDb();
          if (!db) throw new Error('DB Error');

          const updateData = {
            last_name: fd.get('last_name') ?? '',
            first_name: fd.get('first_name') ?? '',
            last_name_kana: fd.get('last_name_kana') ?? '',
            first_name_kana: fd.get('first_name_kana') ?? '',
            mobile_phone: fd.get('mobile_phone') ?? '',
            phone_number: fd.get('phone_number') ?? '',
            home_phone: fd.get('phone_number') ?? '',
            postal_code: fd.get('postal_code') ?? '',
            post_code: fd.get('postal_code') ?? '',
            prf: fd.get('prf') ?? '',
            prefectures: fd.get('prf') ?? '',
            address: fd.get('address') ?? '',
            room_number: fd.get('room_number') ?? '',
            payment_method: fd.get('payment_method') ?? '',
            pet_ride: fd.get('pet_ride') ?? '',
            pet: fd.get('pet_ride') ?? '',
            memo: fd.get('memo') ?? '',
            updated_at: new Date(),
          };

          await updateDoc(doc(db, 'members', memberDocId), updateData);

          if (currentMemberCode) {
            try {
              const fmRes = await fetch('https://roadcruise-share.com/api/filemaker/update', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  ...(apiToken ? { 'Authorization': 'Bearer ' + apiToken } : {}),
                },
                body: JSON.stringify({
                  database: 'webapp',
                  layout_name: 'members',
                  query_key: 'member_code',
                  query_value: currentMemberCode,
                  data: {
                    last_name: fd.get('last_name'),
                    first_name: fd.get('first_name'),
                    last_name_kana: fd.get('last_name_kana'),
                    first_name_kana: fd.get('first_name_kana'),
                    mobile_phone: fd.get('mobile_phone'),
                    home_phone: (fd.get('phone_number') ?? '').toString().trim() || '-',
                    post_code: (fd.get('postal_code') ?? '').toString().replace(/-/g, ''),
                    prefectures: fd.get('prf'),
                    address: fd.get('address'),
                    room_number: (fd.get('room_number') ?? '').toString().trim() || '-',
                    payment_method: fd.get('payment_method'),
                    pet: fd.get('pet_ride'),
                    memo: (fd.get('memo') ?? '').toString().trim() || '-',
                  },
                }),
              });
              if (!fmRes.ok) {
                console.error('FileMaker Update Error:', await fmRes.text());
              }
            } catch (fmErr) {
              console.error('FileMaker Sync Failed:', fmErr);
            }
          }

          if (currentMemberCode) {
            try {
              const user = getCurrentUser();
              const laravelRes = await fetch('https://roadcruise-share.com/api/members/update-by-code', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'Accept': 'application/json',
                  ...(apiToken ? { 'Authorization': 'Bearer ' + apiToken } : {}),
                },
                body: JSON.stringify({
                  member_code: currentMemberCode,
                  last_name: fd.get('last_name'),
                  first_name: fd.get('first_name'),
                  last_name_kana: fd.get('last_name_kana'),
                  first_name_kana: fd.get('first_name_kana'),
                  mobile_phone: fd.get('mobile_phone'),
                  phone_number: fd.get('phone_number'),
                  postal_code: (fd.get('postal_code') ?? '').toString().replace(/-/g, ''),
                  prf: fd.get('prf'),
                  address: fd.get('address'),
                  room_number: fd.get('room_number'),
                  memo: fd.get('memo'),
                  ...(user?.email ? { email: user.email } : {}),
                }),
              });
              if (!laravelRes.ok) {
                console.error('Laravel Update Error:', await laravelRes.text());
              } else {
                console.log('Laravel Update Success');
              }
            } catch (laravelErr) {
              console.error('Laravel Sync Failed:', laravelErr);
            }
          }

          alert('会員情報を更新しました。');
          window.location.href = '/member-info';
        } catch (err) {
          console.error(err);
          alert('更新に失敗しました。');
          submitBtn.disabled = false;
          submitBtn.textContent = '更新する';
        }
      });
    </script>
  </body>
</html>
